# Environment Variables
# Copy this file to .env and fill in the values

# Arbitrum RPC URL for deployment (required)
STYLUS_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# Private key for deployment (required) [secret]
DEPLOYER_PRIVATE_KEY=

# Deployed ERC721 NFT address
NEXT_PUBLIC_NFT_ADDRESS=

# URL of the ERC721 deployment API
ERC721_DEPLOYMENT_API_URL=http://localhost:4001

# AIXBT API Key for market intelligence (required) [secret]
AIXBT_API_KEY=

# Dune Analytics API key for blockchain data queries (required) [secret]
DUNE_API_KEY=

# Pinata API key (required) [secret]
PINATA_API_KEY=

# Pinata secret API key (required) [secret]
PINATA_SECRET_KEY=

# Pinata gateway URL
NEXT_PUBLIC_PINATA_GATEWAY=https://gateway.pinata.cloud

# WalletConnect Cloud project ID for wallet connections (required)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Application name displayed in wallet dialogs
NEXT_PUBLIC_APP_NAME=My DApp

# Bot token from @BotFather (required) [secret]
TELEGRAM_BOT_TOKEN=